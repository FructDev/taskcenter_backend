# ============================================================
# BACKEND - Variables de Entorno
# Copia este archivo como .env y rellena los valores reales
# NUNCA subas el archivo .env a git
# ============================================================

# --- Base de Datos ---
# Cadena de conexión a MongoDB Atlas o local
# Ejemplo Atlas:  mongodb+srv://<usuario>:<password>@cluster0.xxxxx.mongodb.net/<nombre_db>?retryWrites=true&w=majority
# Ejemplo local:  mongodb://localhost:27017/taskcenter
DATABASE_URL=mongodb://localhost:27017/taskcenter

# --- Autenticación JWT ---
# Cadena aleatoria y segura. Genera una con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_seguro

# --- Cloudinary (subida de imágenes) ---
# Obtén estos valores en https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# --- Firebase Admin SDK (notificaciones push) ---
# Obtén estos valores en Firebase Console > Configuración del proyecto > Cuentas de servicio
# > Generar nueva clave privada (descarga el JSON y copia los valores aquí)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
